{
  "manifest_version": 3,
  "name": "eLearning Helper",
  "version": "1.0.0",
  "description": "攔截彈出視窗改為新分頁，並自動連續播放影片",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "eLearning Helper"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
